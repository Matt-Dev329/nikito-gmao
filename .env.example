# ============================================================
# NIKITO GMAO · Variables d'environnement
# Copier ce fichier vers .env.local et remplir
# ============================================================

# Supabase (obligatoire)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (optionnel mais recommandé prod)
VITE_SENTRY_DSN=

# Environnement (dev | staging | prod)
VITE_ENV=dev

